{
  "manifest_version": 3,
  "name": "Break the habbit",
  "version": "1.0.0",
  "description": "Blocks configured domains with a full-screen overlay.",
  "permissions": ["storage"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
